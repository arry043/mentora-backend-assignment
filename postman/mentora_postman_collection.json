                        "url": {
                            "raw": "{{baseUrl}}/llm/summarize",
                            "host": ["{{baseUrl}}"],
                            "path": ["llm", "summarize"]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "const allowed = [200, 502, 503, 429];",
                                    "pm.test('Status is expected for LLM endpoint', function () {",
                                    "  pm.expect(allowed).to.include(pm.response.code);",
                                    "});",
                                    "const json = pm.response.json();",
                                    "if (pm.response.code === 200) {",
